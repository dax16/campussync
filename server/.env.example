# Runtime
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/campussync

# Security
# Use a long, random value and never commit the real secret.
JWT_SECRET=replace_with_a_long_random_secret

# CORS
# CLIENT_URL preserves existing frontend compatibility.
CLIENT_URL=http://localhost:3000
# Optional comma-separated allowlist for multiple frontend origins.
CORS_ORIGINS=http://localhost:3000

# Services
AI_SERVICE_URL=http://localhost:8000

# Email (optional - for booking confirmations)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
