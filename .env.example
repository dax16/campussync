# CampusSync — Docker environment template
# Copy this file to .env and fill in your values before running docker compose.
#
#   cp .env.example .env
#
# docker compose reads .env automatically from the project root.
# These variables are injected into the server container at runtime.

# ─── Required ─────────────────────────────────────────────────────────────────

# Must be a long, random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ─── Optional ─────────────────────────────────────────────────────────────────

# Gmail credentials for booking confirmation emails (leave blank to disable).
EMAIL_USER=
EMAIL_PASS=
