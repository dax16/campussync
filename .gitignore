# ============================================================
# CampusSync — .gitignore
# ============================================================

# ─── Docker secrets (root .env is read by docker compose) ───
.env

# ─── Node.js ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml

# ─── TypeScript ─────────────────────────────────────────────
dist/
*.tsbuildinfo

# ─── React / Create React App ───────────────────────────────
build/
.cache/

# ─── Environment Variables ──────────────────────────────────
# Keep .env.example — never commit real secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
*.err.log

# ─── Test Coverage ──────────────────────────────────────────
coverage/
.nyc_output/
lcov.info

# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
*.dist-info/
venv/
env/
.venv/
pip-log.txt
.pytest_cache/
.coverage
htmlcov/

# ─── OS ─────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Editor / IDE ───────────────────────────────────────────
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.sw?
*.bak
*.orig

# ─── Security ───────────────────────────────────────────────
*.pem
*.key
*.cert

# ─── Deployment ─────────────────────────────────────────────
.vercel
.netlify

# ─── Temp & Scratch ─────────────────────────────────────────
temp.txt
*.tmp
*.temp

# ─── Claude Code (local AI assistant config) ────────────────
.claude/

# ─── Pre-migration JS stubs (superseded by server/src TypeScript)
server/app.js
server/index.js
server/config/
server/middleware/
server/models/
server/routes/
server/socket/
